@model Brand_Clothes_Store.Models.Payment

@{
    ViewData["Title"] = "Edit Payment";
}

<h2>Edit Payment</h2>

<form asp-action="Edit">
    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label asp-for="OrderId"></label>
        <select asp-for="OrderId" class="form-control" asp-items="ViewBag.OrderId">
            <option value="">-- Select Order --</option>
        </select>
        <span asp-validation-for="OrderId" class="text-danger"></span>

    </div>

    <div class="form-group">
        <label asp-for="Amount"></label>
        <input asp-for="Amount" class="form-control" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="paymentMethod"></label>
        <select asp-for="paymentMethod" class="form-control" asp-items="Html.GetEnumSelectList<Brand_Clothes_Store.Models.Enums.PaymentMethod>()">
            <option value="">-- Select Method --</option>
        </select>
        <span asp-validation-for="paymentMethod" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="PaymentStatus"></label>
        <select asp-for="PaymentStatus" class="form-control" asp-items="Html.GetEnumSelectList<Brand_Clothes_Store.Models.Enums.PaymentStatus>()">
            <option value="">-- Select Status --</option>
        </select>
        <span asp-validation-for="PaymentStatus" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="CreatedAt"></label>
        <input asp-for="CreatedAt" type="date" class="form-control" />
        <span asp-validation-for="CreatedAt" class="text-danger"></span>
    </div>

    <br />
    <button type="submit" class="btn btn-primary">Save Changes</button> |
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>
