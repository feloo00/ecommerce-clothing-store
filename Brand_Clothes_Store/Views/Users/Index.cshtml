@model List<Brand_Clothes_Store.Models.ApplicationUser>

<div class="container mt-5">
    <h2 class="mb-4">Users</h2>

    <div class="row">
        @foreach (var user in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card shadow p-3">

                    <h5>@(user.UserName ?? "Google User")</h5>
                    <p><strong>ID:</strong> @user.Id</p>

                    <a href="/Users/Details/@user.Id" class="btn btn-primary">View Details</a>
                </div>
            </div>
        }
    </div>
</div>
