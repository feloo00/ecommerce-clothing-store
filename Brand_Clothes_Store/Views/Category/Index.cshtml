@model IEnumerable<Brand_Clothes_Store.Models.Category>

@{
    ViewData["Title"] = "Categories";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="text-primary fw-bold">Categories</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Add New Category
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No categories available yet.</div>
}
else
{
    <table class="table table-hover table-striped shadow-sm rounded">
        <thead class="table-dark text-center">
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th style="width: 200px;">Actions</th>
            </tr>
        </thead>
        <tbody class="align-middle text-center">
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-semibold">@item.Name</td>
                    <td>
                        @if (string.IsNullOrWhiteSpace(item.Description))
                        {
                            <span class="badge bg-secondary">No Description</span>
                        }
                        else
                        {
                            @item.Description
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm me-1">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm me-1">
                            <i class="bi bi-pencil-square"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                            <i class="bi bi-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
