@model Brand_Clothes_Store.Models.Category

@{
    ViewData["Title"] = "Delete Category";
}

<div class="alert alert-danger mt-3 p-4 rounded shadow-sm">
    <h4 class="text-danger"><i class="bi bi-exclamation-triangle"></i> Delete Confirmation</h4>
    <p>Are you sure you want to delete the category <strong>@Model.Name</strong>?</p>

    <form asp-action="Delete" method="post" class="mt-3">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger me-2">
            <i class="bi bi-trash"></i> Delete
        </button>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-x-circle"></i> Cancel
        </a>
    </form>
</div>
