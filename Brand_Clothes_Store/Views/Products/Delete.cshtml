@model Brand_Clothes_Store.Models.Product

@{
    ViewData["Title"] = "Delete Product";
}

<div class="container mt-5">
    <div class="card shadow-lg border-danger rounded-4">
        <div class="card-header bg-danger text-white">
            <h3 class="mb-0">Delete Product</h3>
        </div>

        <div class="card-body p-4">
            <h5 class="text-danger fw-bold">Are you sure you want to delete this product?</h5>
            <dl class="row mt-3">
                <dt class="col-sm-4 fw-bold">Name</dt>
                <dd class="col-sm-8">@Model.Name</dd>

                <dt class="col-sm-4 fw-bold">Category</dt>
                <dd class="col-sm-8">@Model.Category?.Name ?? "—"</dd>

                <dt class="col-sm-4 fw-bold">Price</dt>
                <dd class="col-sm-8">@Model.BasePrice.ToString("C2")</dd>
            </dl>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-secondary rounded-pill">
                        <i class="bi bi-arrow-left"></i> Cancel
                    </a>
                    <button type="submit" class="btn btn-danger rounded-pill">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
