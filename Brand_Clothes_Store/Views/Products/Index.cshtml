@model IEnumerable<Brand_Clothes_Store.Models.Product>

@{
    ViewData["Title"] = "Products List";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">Products</h2>
        <a asp-action="Create" class="btn btn-success rounded-pill">
            <i class="bi bi-plus-circle"></i> Add New Product
        </a>
    </div>

    <table class="table table-striped table-hover shadow-sm">
        <thead class="table-primary text-center">
            <tr>
                <th>Image</th>
                <th>Name</th>
                <th>Category</th>
                <th>Base Price</th>
                <th>Status</th>
                <th>Created At</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody class="align-middle text-center">
            @foreach (var product in Model)
            {
                <tr>
                    <td>
                        <img src="@product.ImageUrl" alt="Image" width="70" height="70" class="rounded-3 border" style="object-fit:cover;" />
                    </td>
                    <td>@product.Name</td>
                    <td>@product.Category?.Name </td>
                    <td class="text-success fw-bold">@product.BasePrice.ToString("C2")</td>
                    <td>
                        <span class="badge bg-@(product.Status.ToString() == "Active" ? "success" : "secondary")">
                            @product.Status
                        </span>
                    </td>
                    <td>@product.CreatedAt.ToString("dd MMM yyyy")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-info btn-sm text-white">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a asp-action="Edit" asp-route-id="@product.Id" class="btn btn-warning btn-sm text-white">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-danger btn-sm">
                            <i class="bi bi-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
