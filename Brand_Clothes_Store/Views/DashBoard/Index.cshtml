@{
    ViewData["Title"] = "Dashboard";
    var stats = ViewBag.Dashboard;
}

<div class="container py-5">

    <!-- Title -->
    <div class="text-center mb-4">
        <h2 class="fw-bold text-dark">Admin Dashboard</h2>
        <p class="text-muted fs-6">Quick overview of your store</p>
    </div>

    <!-- Stats Section -->
    <div class="row justify-content-center g-3 flex-nowrap overflow-auto">

        <div class="col-auto">
            <div class="modern-card shadow-sm py-3 px-4">
                <div class="icon-circle bg-primary bg-opacity-25 text-primary mb-2">
                    <i class="bi bi-tags-fill"></i>
                </div>
                <h6 class="text-muted">Categories</h6>
                <h3 class="fw-bold">@stats.Categories</h3>
            </div>
        </div>

        <div class="col-auto">
            <div class="modern-card shadow-sm py-3 px-4">
                <div class="icon-circle bg-success bg-opacity-25 text-success mb-2">
                    <i class="bi bi-bag-fill"></i>
                </div>
                <h6 class="text-muted">Products</h6>
                <h3 class="fw-bold">@stats.Products</h3>
            </div>
        </div>

        <div class="col-auto">
            <div class="modern-card shadow-sm py-3 px-4">
                <div class="icon-circle bg-warning bg-opacity-25 text-warning mb-2">
                    <i class="bi bi-palette-fill"></i>
                </div>
                <h6 class="text-muted">Variants</h6>
                <h3 class="fw-bold">@stats.Variants</h3>
            </div>
        </div>

        <div class="col-auto">
            <div class="modern-card shadow-sm py-3 px-4">
                <div class="icon-circle bg-danger bg-opacity-25 text-danger mb-2">
                    <i class="bi bi-box-seam"></i>
                </div>
                <h6 class="text-muted">Orders</h6>
                <h3 class="fw-bold">@stats.Orders</h3>
            </div>
        </div>

        <div class="col-auto">
            <div class="modern-card shadow-sm py-3 px-4">
                <div class="icon-circle bg-info bg-opacity-25 text-info mb-2">
                    <i class="bi bi-people-fill"></i>
                </div>
                <h6 class="text-muted">Users</h6>
                <h3 class="fw-bold">@stats.Users</h3>
            </div>
        </div>

    </div>

</div>

    <!-- Quick Navigation -->
    <h3 class="fw-bold mt-5 mb-3">Manage Sections</h3>
    <div class="row g-4">

        <div class="col-md-3">
            <a asp-controller="Category" asp-action="Index" class="text-decoration-none">
                <div class="nav-glass shadow-sm">
                    <i class="bi bi-tags fs-1 text-primary"></i>
                    <h5 class="mt-3 fw-bold text-dark">Categories</h5>
                </div>
            </a>
        </div>

        <div class="col-md-3">
            <a asp-controller="Products" asp-action="Index" class="text-decoration-none">
                <div class="nav-glass shadow-sm">
                    <i class="bi bi-bag fs-1 text-success"></i>
                    <h5 class="mt-3 fw-bold text-dark">Products</h5>
                </div>
            </a>
        </div>

        <div class="col-md-3">
            <a asp-controller="Order" asp-action="Index" class="text-decoration-none">
                <div class="nav-glass shadow-sm">
                    <i class="bi bi-box fs-1 text-danger"></i>
                    <h5 class="mt-3 fw-bold text-dark">Orders</h5>
                </div>
            </a>
        </div>

        <div class="col-md-3">
            <a asp-controller="Users" asp-action="Index" class="text-decoration-none">
                <div class="nav-glass shadow-sm">
                    <i class="bi bi-people fs-1 text-info"></i>
                    <h5 class="mt-3 fw-bold text-dark">Users</h5>
                </div>
            </a>
        </div>

    </div>

</div>

<style>
    .modern-card {
        background: white;
        border-radius: 15px;
        text-align: center;
        min-width: 200px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        
    }

        .modern-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }

    .icon-circle {
        width: 50px;
        height: 50px;
        font-size: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: auto;
        border-radius: 50%;
    }

    /* Scroll for overflow on small screens */
    .row.flex-nowrap {
        flex-wrap: nowrap;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        padding-bottom: 10px;
    }

        .row.flex-nowrap::-webkit-scrollbar {
            height: 6px;
        }

        .row.flex-nowrap::-webkit-scrollbar-thumb {
            background: rgba(0,0,0,0.2);
            border-radius: 3px;
        }

    /* Navigation Glass Card */
    .nav-glass {
        padding: 35px 20px;
        text-align: center;
        border-radius: 18px;
        backdrop-filter: blur(8px);
        background: rgba(255,255,255,0.6);
        transition: .3s;
        border: 2px solid transparent; 
    }

        .nav-glass:hover {
            transform: translateY(-7px) scale(1.04);
            background: rgba(255,255,255,0.9); 
            border-color: rgba(0, 123, 255, 0.3); 
            box-shadow: 0 12px 35px rgba(0,0,0,0.18);
        }

</style>

    

