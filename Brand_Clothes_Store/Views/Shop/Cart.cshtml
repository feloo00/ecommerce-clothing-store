@model List<Brand_Clothes_Store.Models.OrderItem>

@{
    ViewData["Title"] = "My Cart";
    var total = Model.Sum(i => i.TotalPrice);
}

<div class="container py-5">
    <h2 class="text-center mb-4 fw-bold text-uppercase text-primary">🛒 Your Shopping Cart</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center fs-5">
            Your cart is empty ! <br />
            <a asp-action="Browse" asp-controller="Shop" class="btn btn-outline-primary mt-3">Continue Shopping</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered align-middle text-center shadow-sm">
                <thead class="table-dark">
                    <tr>
                        <th>Product</th>
                        <th>Variant</th>
                        <th>Quantity</th>
                        <th>Unit Price</th>
                        <th>Total Price</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Variant.Product.Name</td>
                            <td>@item.Variant.Size</td>
                            <td>
                                <div class="d-flex justify-content-center align-items-center gap-2">
                                    <form asp-action="DecreaseQuantity" method="post" class="ajax-action">
                                        <input type="hidden" name="variantId" value="@item.VariantId" />
                                        <button type="submit" class="btn btn-sm btn-outline-secondary">−</button>
                                    </form>

                                    <span class="fw-bold">@item.Quantity</span>

                                    <form asp-action="IncreaseQuantity" method="post" class="ajax-action">
                                        <input type="hidden" name="variantId" value="@item.VariantId" />
                                        <button type="submit" class="btn btn-sm btn-outline-secondary">+</button>
                                    </form>
                                </div>
                            </td>
                            <td>@item.UnitPrice.ToString("0.00") EGP</td>
                            <td>@item.TotalPrice.ToString("0.00") EGP</td>
                            <td>
                                <form asp-action="RemoveItem" method="post" class="ajax-action">
                                    <input type="hidden" name="variantId" value="@item.VariantId" />
                                    <button type="submit" class="btn btn-danger btn-sm">
                                        <i class="bi bi-trash"></i> Remove
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="text-end mt-4">
            <h4 class="fw-bold">Total: <span id="cartTotal" class="text-success">@total.ToString("0.00") EGP</span></h4>
        </div>

        <div class="d-flex justify-content-end gap-3 mt-4">
            <a asp-controller="Shop" asp-action="Browse" class="btn btn-outline-secondary px-4 fw-semibold">
                Continue Shopping
            </a>

            <form asp-action="OrderNow" method="post">
                <button type="submit" class="btn btn-primary px-4 fw-semibold">Order Now</button>
            </form>

            <form asp-action="CashOnDelivery" method="post">
                <button type="submit" class="btn btn-success px-4 fw-semibold">Cash on Delivery</button>
            </form>
        </div>

    }
</div>

@section Scripts {
    <script>
        // 🌀 Update total dynamically
        function updateCart() {
            fetch('/Shop/GetCartSummary')
                .then(res => res.json())
                .then(data => {
                    document.getElementById("cartTotal").innerText = data.total.toFixed(2) + " EGP";
                });
        }

        // 🎯 Handle AJAX actions (increase/decrease/remove)
        document.querySelectorAll("form.ajax-action").forEach(form => {
            form.addEventListener("submit", function (e) {
                e.preventDefault();
                fetch(form.action, {
                    method: "POST",
                    body: new FormData(form)
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        location.reload(); // مؤقت — ممكن بعدين نعملها Dynamic بدون reload
                    }
                });
            });
        });
    </script>
}
