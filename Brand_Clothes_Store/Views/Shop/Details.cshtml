@model Brand_Clothes_Store.Models.Product
@{
    ViewData["Title"] = "Product Details";
}

<div class="container mt-5">
    <div class="card shadow-lg p-4 border-0 rounded-4">
        <div class="row g-4">
            <!-- Product Image -->
            <div class="col-md-5 text-center">
                <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded-3 shadow-sm" style="max-height: 400px; object-fit: cover;">
            </div>

            <!-- Product Info -->
            <div class="col-md-7 d-flex flex-column justify-content-between">
                <div>
                    <h2 class="fw-bold">@Model.Name</h2>
                    @* <h6 class="text-success m-0">@Model.Status</h6> *@
                    <span class="badge bg-@(Model.Status.ToString() == "Active" ? "success" : "secondary")">
                        @Model.Status
                    </span>

                    <p class="mt-3 fs-5">
                        <strong>Category:</strong> @Model.Category.Name
                    </p>

                    <p class="mt-3">@Model.Description</p>

                    <h3 class="text-success fw-bold mt-4">@Model.BasePrice.ToString() EGP</h3>

                    <!-- Variants Section -->
                    @if (Model.Variants != null && Model.Variants.Any())
                    {
                        <form asp-action="AddToCart" asp-controller="Shop" method="post" class="mt-4">
                            <label for="variantSelect" class="form-label fw-bold">Choose a Variant:</label>
                            <select id="variantSelect" name="variantId" class="form-select mb-3" required>
                                @foreach (var variant in Model.Variants)
                                {
                                    <option value="@variant.Id">
                                        @variant.Color - @variant.Size 
                                        
                                    </option>
                                }
                            </select>

                            <button type="submit" class="btn btn-dark px-4 py-2 rounded-pill shadow-sm me-2">
                                <i class="bi bi-cart-plus me-1"></i> Add to Cart
                            </button>
                            <a asp-action="Browse" asp-controller="Shop" class="btn btn-outline-secondary px-4 py-2 rounded-pill">
                                Back to Products
                            </a>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-warning mt-4">
                            No variants available for this product.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
