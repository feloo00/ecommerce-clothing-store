@model IEnumerable<Brand_Clothes_Store.Models.Product>
@{
    ViewData["Title"] = "Shop";
}

<div class="container py-5">

    <div class="text-center mb-5">
        <h2 class="fw-bold text-dark display-5 animate__animated animate__fadeInDown">
            🛒 Find Your Perfect Outfit Today!
        </h2>
        <p class="text-muted fs-6 mt-2 animate__animated animate__fadeInUp animate__delay-1s">
            Explore our exclusive collection and find your perfect style
        </p>
    </div>


    <div class="row g-4">
        @foreach (var product in Model)
        {
            <div class="col-sm-6 col-md-4 col-lg-3">
                <div class="card product-card h-100 border-0 shadow-sm position-relative overflow-hidden">

                    <!-- Product Image -->
                    <img src="@product.ImageUrl" class="card-img-top product-img" />

                    <!-- Overlay Hover -->
                    <div class="card-overlay d-flex flex-column justify-content-center align-items-center text-center">
                        <button class="btn-fav @(product.IsFavorite ? "favorited" : "")"
                                data-id="@product.Id"
                                onclick="toggleFavorite(this)">
                            <i class="bi bi-heart-fill"></i>
                        </button>




                        <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-outline-light mb-2">View Details</a>
                        <form asp-controller="Shop" asp-action="AddToCart" method="post">
                            <input type="hidden" name="id" value="@product.Id" />

                        </form>

                    </div>

                    <div class="card-body text-center">
                        <h5 class="card-title fw-semibold">@product.Name</h5>
                        <p class="text-muted mb-1">@product.Category?.Name</p>
                        <p class="fw-bold fs-5" style="color: #541a2e;">
                            @product.BasePrice.ToString("N0") EGP
                        </p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    /* Card Styling */
    .product-card {
        border-radius: 15px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        cursor: pointer;
    }

        .product-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.2);
        }

    .product-img {
        height: 250px;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .product-card:hover .product-img {
        transform: scale(1.1);
    }

    /* Overlay Hover */
    .card-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.5);
        opacity: 0;
        transition: opacity 0.3s ease;
        border-radius: 15px;
    }

    .product-card:hover .card-overlay {
        opacity: 1;
    }

    .card-overlay .btn {
        min-width: 120px;
        border-radius: 50px;
        transition: transform 0.2s ease;
        background-color: #541A2E;
        color: #FBE4D8;
        border: none;
    }


    .product-card .card-body {
        background-color: #FBE4D8;
        border-radius: 0 0 15px 15px;
    }

    .card-overlay .btn:hover {
        transform: scale(1.05);
        background-color: #B51A2B;
    }

    .btn-fav {
        position: absolute;
        top: 10px;
        right: 10px;
        background: white;
        color: #541A2E;
        border-radius: 50%;
        border: none;
        width: 42px;
        height: 42px;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 20px;
    }

        .btn-fav.favorited {
            background: #B51A2B;
            color: #FBE4D8;
        }


        .btn-fav:hover {
            transform: scale(1.15);
        }

    /* نبضة القلب عند الضغط */
    @@keyframes heartPulse {
        0% {
            transform: scale(1);
        }

        30% {
            transform: scale(1.3);
        }

        60% {
            transform: scale(0.9);
        }

        100% {
            transform: scale(1);
        }
    }

    .btn-fav.animate-heart i {
        animation: heartPulse 0.4s ease;
    }

</style>
<script>
            function toggleFavorite(btn) {
        const productId = btn.getAttribute('data-id');
        const icon = btn.querySelector('i');

        fetch('/Shop/ToggleFavorite', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': '@@Antiforgery.GetTokens(HttpContext).RequestToken'
            },
            body: JSON.stringify({ productId: productId })
        })
        .then(response => response.json())
        .then(data => {

            // toggle اللون
            if (data.isFavorited) {
                btn.classList.add('favorited');
            } else {
                btn.classList.remove('favorited');
            }

            // ✨ تشغيل الأنيميشن
            btn.classList.add("animate-heart");

            // نشيل الكلاس بعد الأنيميشن
            setTimeout(() => {
                btn.classList.remove("animate-heart");
            }, 400);
        });
    }


</script>
