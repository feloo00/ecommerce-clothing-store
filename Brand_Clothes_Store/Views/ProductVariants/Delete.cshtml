@model Brand_Clothes_Store.Models.ProductVariant

@{
    ViewData["Title"] = "Delete Product Variant";
}

<h2 class="text-center text-danger mb-4">Delete Product Variant</h2>

<h4>Are you sure you want to delete this variant?</h4>
<hr />

<div class="card p-4 shadow-sm">
    <dl class="row">
        <dt class="col-sm-3">Product</dt>
        <dd class="col-sm-9">@Model.Product?.Name</dd>

        <dt class="col-sm-3">Color</dt>
        <dd class="col-sm-9">@Model.Color</dd>

        <dt class="col-sm-3">Size</dt>
        <dd class="col-sm-9">@Model.Size</dd>

        <dt class="col-sm-3">Price</dt>
        <dd class="col-sm-9">@Model.Price</dd>
    </dl>
</div>

<form asp-action="DeleteConfirmed" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
