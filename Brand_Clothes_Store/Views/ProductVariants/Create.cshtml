@model Brand_Clothes_Store.Models.ProductVariant

@{
    ViewData["Title"] = "Create Product Variant";
    var sizes = new List<string> { "XS", "S", "M", "L", "XL", "XXL" };
}

<div class="container mt-4">
    <h2 class="mb-4 text-center">Add New Product Variant</h2>

    <form asp-action="Create" method="post">
        <div class="card p-4 shadow-sm">

            <!-- Product Dropdown -->
            <div class="mb-3">
                <label asp-for="ProductId" class="form-label">Select Product</label>
                <select asp-for="ProductId" class="form-control" asp-items="ViewBag.Products">
                    <option value="">-- Choose a Product --</option>
                </select>
                <span asp-validation-for="ProductId" class="text-danger"></span>
            </div>

            <!-- Color -->
            <div class="mb-3">
                <label asp-for="Color" class="form-label"></label>
                <input asp-for="Color" class="form-control" placeholder="Enter color (e.g. Black, Blue)" />
                <span asp-validation-for="Color" class="text-danger"></span>
            </div>

            <!-- Size Dropdown -->
            <div class="mb-3">
                <label asp-for="Size" class="form-label"></label>
                <select asp-for="Size" class="form-select">
                    <option value="">-- Choose Size --</option>
                    @foreach (var size in sizes)
                    {
                        <option value="@size">@size</option>
                    }
                </select>
                <span asp-validation-for="Size" class="text-danger"></span>
            </div>

            <!-- Stock -->
            <div class="mb-3">
                <label asp-for="Stock" class="form-label"></label>
                <input asp-for="Stock" class="form-control" placeholder="Enter quantity in stock" />
                <span asp-validation-for="Stock" class="text-danger"></span>
            </div>

            <!-- Image URL -->
            <div class="mb-3">
                <label asp-for="ImageUrl" class="form-label"></label>
                <input asp-for="ImageUrl" class="form-control" id="imageUrlInput" placeholder="Enter image URL" />
                <span asp-validation-for="ImageUrl" class="text-danger"></span>

                <!-- Image Preview -->
                <div class="mt-3 text-center">
                    <img id="imagePreview" src="#" alt="Image Preview" class="img-thumbnail" style="max-width: 200px; display: none;" />
                </div>
            </div>

            <!-- Info Note -->
            <div class="alert alert-info mt-3">
                💡 The price will be automatically taken from the selected product.
            </div>

            <!-- Buttons -->
            <div class="d-flex justify-content-between mt-4">
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                <button type="submit" class="btn btn-primary">Create Variant</button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Image preview script
        const imageInput = document.getElementById('imageUrlInput');
        const imagePreview = document.getElementById('imagePreview');

        imageInput.addEventListener('input', function () {
            const url = imageInput.value.trim();
            if (url) {
                imagePreview.src = url;
                imagePreview.style.display = 'block';
            } else {
                imagePreview.style.display = 'none';
            }
        });
    </script>
}
