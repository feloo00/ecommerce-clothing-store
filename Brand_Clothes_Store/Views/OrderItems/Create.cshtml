@model Brand_Clothes_Store.Models.OrderItem
@{
    ViewData["Title"] = "Create Order Item";
    var orders = ViewBag.Orders as List<Brand_Clothes_Store.Models.Order>;
    var products = ViewBag.Products as List<Brand_Clothes_Store.Models.Product>;
}

<h2>Create Order Item</h2>

<form asp-action="Create" method="post">
    <div class="form-group">
        <label>Order</label>
        <select asp-for="OrderId" class="form-control" required>
            <option value="">-- Select Order --</option>
            @foreach (var o in orders)
            {
                <option value="@o.Id">Order #@o.Id</option>
            }
        </select>
    </div>

    <div class="form-group mt-3">
        <label>Product</label>
        <select class="form-control product-dropdown">
            <option value="">-- Select Product --</option>
            @foreach (var p in products)
            {
                <option value="@p.Id">@p.Name</option>
            }
        </select>
    </div>

    <div class="form-group mt-3">
        <label>Variant</label>
        <select asp-for="VariantId" class="form-control variant-dropdown" required>
            <option value="">-- Select Variant --</option>
        </select>
    </div>

    <div class="form-group mt-3">
        <label asp-for="Quantity"></label>
        <input asp-for="Quantity" class="form-control" type="number" min="1" />
    </div>

    <div class="form-group mt-3">
        <label asp-for="UnitPrice"></label>
        <input asp-for="UnitPrice" class="form-control" type="number" step="0.01" readonly />
    </div>

    <div class="form-group mt-3">
        <label asp-for="TotalPrice"></label>
        <input asp-for="TotalPrice" class="form-control" type="number" step="0.01" readonly />
    </div>

    <button type="submit" class="btn btn-success mt-3">Create</button>
</form>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        // لما المستخدم يختار Product
        $(".product-dropdown").change(function () {
            let productId = $(this).val();
            let variantDropdown = $(".variant-dropdown");

            if (productId) {
                $.getJSON(`/OrderItems/GetVariantsByProduct?productId=${productId}`, function (data) {
                    variantDropdown.empty().append('<option value="">-- Select Variant --</option>');
                    $.each(data, function (i, v) {
                        variantDropdown.append(`<option value="${v.id}" data-price="${v.price}">${v.color || ''} ${v.size || ''}</option>`);
                    });
                });
            }
        });

        // لما المستخدم يختار Variant
        $(".variant-dropdown").change(function () {
            let price = $("option:selected", this).data("price");
            $("#UnitPrice").val(price || 0);
            calculateTotal();
        });

        // لما يغير الكمية
        $("#Quantity").on("input", function () {
            calculateTotal();
        });

        function calculateTotal() {
            let qty = parseFloat($("#Quantity").val()) || 0;
            let price = parseFloat($("#UnitPrice").val()) || 0;
            $("#TotalPrice").val(qty * price);
        }
    </script>
}
