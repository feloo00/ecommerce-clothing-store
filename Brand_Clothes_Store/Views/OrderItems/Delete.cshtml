@model Brand_Clothes_Store.Models.OrderItem

@{
    ViewData["Title"] = "Delete Order Item";
}

<h2 class="text-danger mb-4">Delete Order Item</h2>

<h4>Are you sure you want to delete this item?</h4>
<hr />

<div class="card shadow-sm p-4">
    <dl class="row">
        <dt class="col-sm-3">Order</dt>
        <dd class="col-sm-9">@Model.OrderId</dd>

        <dt class="col-sm-3">Product Variant</dt>
        <dd class="col-sm-9">@Model.VariantId</dd>

        <dt class="col-sm-3">Quantity</dt>
        <dd class="col-sm-9">@Model.Quantity</dd>

        <dt class="col-sm-3">Unit Price</dt>
        <dd class="col-sm-9">@Model.UnitPrice.ToString("C")</dd>

        <dt class="col-sm-3">Total Price</dt>
        <dd class="col-sm-9">@Model.TotalPrice.ToString("C")</dd>
    </dl>

    <form asp-action="DeleteConfirmed" method="post">
        <input type="hidden" asp-for="Id" />

        <div class="mt-4 d-flex gap-2">
            <input type="submit" value="Delete" class="btn btn-danger" />
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
