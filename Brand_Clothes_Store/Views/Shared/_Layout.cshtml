@using Microsoft.AspNetCore.Identity
@inject SignInManager<Brand_Clothes_Store.Models.ApplicationUser> SignInManager
@inject UserManager<Brand_Clothes_Store.Models.ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Brand Clothes Store</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

    <style>
        /* === Navbar فقط === */
        .navbar-custom {
            background-color: #161e2f !important;
        }

            .navbar-custom .nav-link {
                color: #FBE4D8 !important;
                transition: 0.2s ease;
                font-weight: 500;
            }

                .navbar-custom .nav-link:hover {
                    color: #B51A2B !important;
                    transform: translateY(-2px);
                }

        /* Dropdown */
        .dropdown-menu {
            background-color: #242f49;
            border: 1px solid #FBE4D8;
        }

        .dropdown-item {
            color: #FBE4D8;
            transition: 0.2s;
        }

            .dropdown-item:hover {
                background-color: #541A2E;
                color: white;
            }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">

    <nav class="navbar navbar-expand-lg navbar-dark navbar-custom shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="bi bi-shop fs-3 me-2"></i>Brand Clothes
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon" style="background-color:#FBE4D8"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <!-- LHS -->
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-door me-1"></i>Home
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link position-relative" asp-controller="Shop" asp-action="Cart">
                            <i class="bi bi-cart me-1"></i>Cart
                            <span class="badge rounded-pill position-absolute top-0 start-100 translate-middle"
                                  style="color: #B51A2B" id="cartCount">0</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Shop" asp-action="Myorders">
                            <i class="bi bi-bag-check me-1"></i>My Orders
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link position-relative" asp-controller="Shop" asp-action="MyFavourite">
                            <i class="bi bi-heart me-1"></i>Favourites
                            <span class="badge rounded-pill position-absolute top-0 start-100 translate-middle"
                                  style="color: #B51A2B" id="favCount">
                                @(ViewBag.FavCount ?? 0)
                            </span>

                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="AboutUs">
                            <i class="bi bi-info-circle me-1"></i>About
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="ContactUs">
                            <i class="bi bi-telephone me-1"></i>Contact
                        </a>
                    </li>

                    @if (SignInManager.IsSignedIn(User) && User.IsInRole("Admin"))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-shield-lock me-1"></i>Admin Panel
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="DashBoard" asp-action="Index">DashBoard</a></li>
                                <li><a class="dropdown-item" asp-controller="Category" asp-action="Index">Categories</a></li>
                                <li><a class="dropdown-item" asp-controller="Products" asp-action="Index">Products</a></li>
                                <li><a class="dropdown-item" asp-controller="ProductVariants" asp-action="Index">Variants</a></li>
                                <li><a class="dropdown-item" asp-controller="Order" asp-action="Index">Orders</a></li>
                                <li><a class="dropdown-item" asp-controller="OrderItems" asp-action="Index">Order Items</a></li>
                                <li><a class="dropdown-item" asp-controller="Users" asp-action="Index">Users</a></li>
                            </ul>
                        </li>
                    }
                </ul>

                <!-- RHS Auth -->
                <ul class="navbar-nav ms-auto">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <li class="nav-item">
                            <form method="post" asp-controller="Account" asp-action="Logout">
                                <button type="submit" class="btn btn-outline-light fw-bold">
                                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link btn btn-outline-light fw-bold" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right me-1"></i>Login
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <footer class="text-center text-muted py-3 mt-5">
        &copy; 2025 Brand Clothes Store — Premium Edition
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
