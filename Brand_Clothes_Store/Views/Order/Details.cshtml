@model Brand_Clothes_Store.Models.Order
@using Brand_Clothes_Store.Models.Enums


@{
    ViewData["Title"] = "Order Details";
}

<h2>Order Details</h2>

<div class="card p-4 shadow-sm">
    <dl class="row">
        <dt class="col-sm-3">Order ID</dt>
        <dd class="col-sm-9">@Model.Id</dd>

        <dt class="col-sm-3">Customer</dt>
        <dd class="col-sm-9">@Model.User?.FullName</dd>

        <dt class="col-sm-3">Created At</dt>
        <dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd")</dd>

        <dt class="col-sm-3">Total Price</dt>
        <dd class="col-sm-9">@Model.TotalPrice.ToString("C")</dd>
        @*
            New,
        Processing,
        Shipped,
        Delivered,
        Cancelled
        *@
        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">
            <span class="badge bg-@(
                  Model.orderStatus == OrderStatus.Cancelled ? "danger" :
                  Model.orderStatus == OrderStatus.New ? "secondary" :
                  Model.orderStatus == OrderStatus.Processing ? "warning" :
                  Model.orderStatus == OrderStatus.Shipped ? "info" :
                  Model.orderStatus == OrderStatus.Delivered ? "success" : "secondary"
        )">
                @Model.orderStatus
            </span>
        </dd>

    </dl>

    <div class="mt-4">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        <a asp-controller="OrderItems" asp-action="Create" asp-route-orderId="@Model.Id" class="btn btn-success">
            + Add Product to this Order
        </a>
    </div>
</div>

@if (Model.OrderItems != null && Model.OrderItems.Any())
{
    <hr />
    <h4>Products in this Order</h4>
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Product</th>
                <th>Quantity</th>
                <th>Unit Price</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.OrderItems)
            {
                <tr>
                    <td>@item.Variant.Product?.Name</td>
                    <td>@item.Quantity</td>
                    <td>@item.UnitPrice.ToString("C")</td>
                    <td>@(item.Quantity* item.UnitPrice)</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted mt-3">No products added to this order yet.</p>
}
