@model IEnumerable<Brand_Clothes_Store.Models.Order>
@using Brand_Clothes_Store.Models.Enums

@{
    ViewData["Title"] = "Orders";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold">Orders</h2>

        @* <a asp-action="Create" class="btn btn-primary rounded-pill px-4">
            <i class="bi bi-plus-circle"></i> Create New Order
        </a> *@
    </div>

    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body p-0">

            <table class="table table-hover mb-0">
                <thead class="table-primary">
                    <tr>
                        <th>Customer</th>
                        <th>Date</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th>Payment</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@item.User?.FullName</td>

                            <td>@item.CreatedAt.ToShortDateString()</td>

                            <td class="fw-bold">@item.TotalPrice EGP</td>

                            <!-- Order Status Badge -->
                            <td>
                                @{
                                    string statusClass = item.orderStatus switch
                                    {
                                        OrderStatus.New => "badge bg-warning text-dark",
                                        OrderStatus.Processing => "badge bg-info text-dark",
                                        OrderStatus.Shipped => "badge bg-primary",
                                        OrderStatus.Delivered => "badge bg-success",
                                        OrderStatus.Cancelled => "badge bg-danger",
                                        _ => "badge bg-secondary"
                                    };
                                }

                                <span class="@statusClass" style="padding: 6px 12px;">
                                    @item.orderStatus
                                </span>
                            </td>

                            <!-- Payment Badge -->
                            <td>
                                @{
                                    string paymentText = item.Payment != null ? item.Payment.ToString() : "Not Paid";
                                    string paymentClass = item.Payment != null ? "badge bg-success" : "badge bg-danger";
                                }

                                <span class="@paymentClass" style="padding: 6px 12px;">
                                    @paymentText
                                </span>
                            </td>

                            <!-- Actions -->
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-primary rounded-pill px-3 me-1">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </a>

                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-info rounded-pill px-3 me-1">
                                    <i class="bi bi-eye-fill"></i> Details
                                </a>

                                <a asp-action="Delete" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </td>

                        </tr>
                    }
                </tbody>

            </table>
        </div>
    </div>

</div>
